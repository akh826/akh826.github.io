{
  "name": "Personal Webpage Static API",
  "version": "1.3.0",
  "description": "Mock JSON endpoints for frontend testing. Static API presets include GET routes only.",
  "endpoints": [
    {
      "id": "health",
      "method": "GET",
      "path": "health.json",
      "title": "Health check",
      "description": "API status and version",
      "simulateStatus": 200
    },
    {
      "id": "users-list",
      "method": "GET",
      "path": "v1/users.json",
      "title": "List users",
      "description": "Paginated user collection",
      "simulateStatus": 200
    },
    {
      "id": "user-1",
      "method": "GET",
      "path": "v1/users/1.json",
      "title": "Get user #1",
      "description": "Single user profile",
      "simulateStatus": 200
    },
    {
      "id": "user-2",
      "method": "GET",
      "path": "v1/users/2.json",
      "title": "Get user #2",
      "description": "Single user profile",
      "simulateStatus": 200
    },
    {
      "id": "posts-list",
      "method": "GET",
      "path": "v1/posts.json",
      "title": "List posts",
      "description": "Blog posts with author references",
      "simulateStatus": 200
    },
    {
      "id": "post-101",
      "method": "GET",
      "path": "v1/posts/101.json",
      "title": "Get post #101",
      "description": "Single post with full content",
      "simulateStatus": 200
    },
    {
      "id": "products-list",
      "method": "GET",
      "path": "v1/products.json",
      "title": "List products",
      "description": "Product catalog sample",
      "simulateStatus": 200
    },
    {
      "id": "error-not-found",
      "method": "GET",
      "path": "errors/not-found.json",
      "title": "Error: Not found",
      "description": "Sample 404-style error payload",
      "simulateStatus": 404
    },
    {
      "id": "error-unauthorized",
      "method": "GET",
      "path": "errors/unauthorized.json",
      "title": "Error: Unauthorized",
      "description": "Sample 401-style error payload",
      "simulateStatus": 401
    },
    {
      "id": "error-server",
      "method": "GET",
      "path": "errors/server-error.json",
      "title": "Error: Server error",
      "description": "Sample 500-style error payload",
      "simulateStatus": 500
    }
  ]
}
